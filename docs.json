            "pages": [
              "guides/basic-usage",
              "guides/advanced-features",
              "guides/theming",
              "guides/data-attributes",
              "guides/examples"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/browser-support",
              "resources/migration",
              "resources/troubleshooting",
              "resources/contributing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
