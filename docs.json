{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Slick Carousel",
  "theme": "palm",
  "colors": {
    "primary": "#3498db",
    "light": "#5dade2",
    "dark": "#2980b9"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/kenwheeler/slick"
    }
  },
  "footer": {
    "socials": {
